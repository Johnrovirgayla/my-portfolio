# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/my-portfolio
# Or use MongoDB Atlas:
# MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/portfolio

# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Secret (use any random string)
JWT_SECRET=your_super_secret_jwt_key_12345

# Email Configuration (Gmail)
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_from_gmail

# Admin Email
ADMIN_EMAIL=joca.gayla.coc@phinmaed.com
NOTIFICATION_EMAIL=joca.gayla.coc@phinmaed.com
